@page "/play"
@inject GameHubService Hub
@inject IJSRuntime JS
@implements IDisposable

@if (Hub.IsKicked)
{
    <div class="join-screen">
        <p>You have been kicked from the game.</p>
    </div>
    return;
}

@if (!Hub.IsConnected)
{
    <div class="join-screen">
        <p>Not connected. <a href="/">Go back to join.</a></p>
    </div>
    return;
}

<div class="game-container">
    @if (State.IsFinalJeopardy)
    {
        <FinalJeopardyPanel />
    }
    else
    {
        <GameBoard />
        <QuestionDisplay />
        <BuzzerPanel />
    }

    <Scoreboard />

    @if (!string.IsNullOrEmpty(State.BoardController))
    {
        <div class="board-controller">Board controlled by @State.BoardController</div>
    }
</div>

@code {
    private GameState State => Hub.CurrentState;

    private static readonly Dictionary<AudioClips, string> AudioFiles = new()
    {
        [AudioClips.Buzz] = "sounds/buzz.mp3",
        [AudioClips.Ding] = "sounds/ding.mp3",
        [AudioClips.Airhorn] = "sounds/mlg-airhorn.mp3",
        [AudioClips.Timeout] = "sounds/timeout.mp3",
        [AudioClips.Wrong] = "sounds/wrong.mp3",
    };

    protected override void OnInitialized()
    {
        Hub.StateChanged += OnStateChanged;
        Hub.AudioClipReceived += OnAudioClip;
    }

    private async void OnStateChanged()
    {
        await InvokeAsync(StateHasChanged);
    }

    private async void OnAudioClip(AudioClips clip)
    {
        if (AudioFiles.TryGetValue(clip, out var src))
        {
            await JS.InvokeVoidAsync("playAudio", src);
        }
    }

    public void Dispose()
    {
        Hub.StateChanged -= OnStateChanged;
        Hub.AudioClipReceived -= OnAudioClip;
    }
}
